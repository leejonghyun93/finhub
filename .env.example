# ============================================================
# FinHub 환경변수 설정 예시
# 이 파일을 복사해서 .env 로 저장하고 실제 값으로 변경하세요.
# cp .env.example .env
# ⚠️ .env 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=your_strong_password_here
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here

# JWT Secret (최소 256비트 이상의 랜덤 문자열)
# 생성 방법: openssl rand -base64 64
JWT_SECRET=your-very-long-random-jwt-secret-key-at-least-256-bits

# Elasticsearch
ELASTIC_PASSWORD=your_elasticsearch_password

# Redis (기본값: localhost:6379, 변경 필요 시)
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka (기본값: localhost:9092, 변경 필요 시)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Eureka (기본값: localhost:8761, 변경 필요 시)
EUREKA_SERVER_URL=http://localhost:8761/eureka/

# Elasticsearch URI (기본값: localhost:9200, 변경 필요 시)
ELASTICSEARCH_URI=http://localhost:9200
